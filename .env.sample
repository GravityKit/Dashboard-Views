# Comma-separated absolute paths to extra plugins to mount into the wp-env test environment.
# Example: WP_ENV_PLUGINS=/path/to/gravityforms
WP_ENV_PLUGINS=

# License keys injected into the test environment.
GRAVITY_FORMS_LICENSE_KEY=
GRAVITYKIT_LICENSE_KEY=

# Optional tunables
# E2E_KEEP_DATA=0      Skip cleanup of test data between runs.
# USE_LOCAL_BROWSER=0  Use local Chromium instead of the Docker Playwright container.
# SLOW_MO=0            Slow down Playwright actions by N milliseconds (useful for debugging).
